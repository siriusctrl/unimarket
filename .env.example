# Required: admin bearer token for /api/admin/* and dashboard admin login
ADMIN_API_KEY=change-me

# Optional: database location
DB_URL=file:unimarket.sqlite

# Optional: scheduler intervals (milliseconds)
RECONCILE_INTERVAL_MS=1000
SETTLE_INTERVAL_MS=60000
FUNDING_INTERVAL_MS=3600000
LIQUIDATION_INTERVAL_MS=5000

# Optional: perp risk settings
MAINTENANCE_MARGIN_RATIO=0.05

# Optional: trading fees (decimal rate, [0, 1))
# If omitted, default taker fee is 0.
DEFAULT_TAKER_FEE_RATE=0
# Market-specific overrides (take precedence over DEFAULT_TAKER_FEE_RATE)
HYPERLIQUID_TAKER_FEE_RATE=0
POLYMARKET_TAKER_FEE_RATE=0
